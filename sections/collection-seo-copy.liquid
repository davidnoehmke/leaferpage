{% liquid
  assign seo_group = 'default'
  if collection.handle contains 'substrat' or collection.title contains 'Substrat'
    assign seo_group = 'substrates'
  elsif collection.handle contains 'pflanzgefass' or collection.handle contains 'pflanzgef' or collection.title contains 'Pflanzgef'
    assign seo_group = 'planters'
  elsif collection.handle contains 'smart-grow' or collection.title contains 'Smart Grow'
    assign seo_group = 'smart_grow'
  elsif collection.handle contains 'pflege' or collection.handle contains 'zubehor' or collection.title contains 'Zubehör'
    assign seo_group = 'care'
  elsif collection.handle contains 'set' or collection.handle contains 'bundle' or collection.title contains 'Set'
    assign seo_group = 'sets'
  endif
  assign heading_key = 'collection_seo.' | append: seo_group | append: '.heading'
  assign lead_key = 'collection_seo.' | append: seo_group | append: '.lead'
  assign body_key = 'collection_seo.' | append: seo_group | append: '.body'
  assign question_one_key = 'collection_seo.' | append: seo_group | append: '.question_one'
  assign answer_one_key = 'collection_seo.' | append: seo_group | append: '.answer_one'
  assign question_two_key = 'collection_seo.' | append: seo_group | append: '.question_two'
  assign answer_two_key = 'collection_seo.' | append: seo_group | append: '.answer_two'
%}
<section class="collection-seo-copy page-width" aria-labelledby="CollectionSeo-{{ section.id }}">
  <div class="collection-seo-copy__body">
    <p class="collection-seo-copy__eyebrow">{{ 'collection_seo.eyebrow' | t }}</p>
    <h2 id="CollectionSeo-{{ section.id }}">{{ heading_key | t }}</h2>
    <p class="collection-seo-copy__lead">{{ lead_key | t }}</p>
    <p>{{ body_key | t }}</p>
  </div>
  <div class="collection-seo-copy__faq">
    <h3>{{ 'collection_seo.faq_heading' | t }}</h3>
    <details><summary>{{ question_one_key | t }}</summary><p>{{ answer_one_key | t }}</p></details>
    <details><summary>{{ question_two_key | t }}</summary><p>{{ answer_two_key | t }}</p></details>
  </div>
</section>

{% stylesheet %}
  .collection-seo-copy { margin-block: var(--space-section); padding-block: clamp(2.5rem, 6vw, 6rem); display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(300px, .8fr); gap: clamp(2rem, 7vw, 8rem); border-top: 1px solid var(--border); }
  .collection-seo-copy__body { max-width: 780px; }
  .collection-seo-copy__eyebrow { margin: 0 0 .6rem; color: var(--accent); font-size: .75rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
  .collection-seo-copy h2 { margin: 0 0 1.5rem; font-size: clamp(2.3rem, 5vw, 4.8rem); line-height: .97; letter-spacing: -.055em; }
  .collection-seo-copy__lead { font-size: clamp(1.1rem, 2vw, 1.35rem); line-height: 1.55; }
  .collection-seo-copy__body > p:last-child { color: var(--muted); }
  .collection-seo-copy__faq h3 { margin-top: 0; font-size: 1.5rem; }
  .collection-seo-copy__faq details { border-top: 1px solid var(--border); }
  .collection-seo-copy__faq details:last-child { border-bottom: 1px solid var(--border); }
  .collection-seo-copy__faq summary { padding-block: 1rem; cursor: pointer; font-weight: 750; }
  .collection-seo-copy__faq p { margin-top: 0; color: var(--muted); }
  @media (max-width: 800px) { .collection-seo-copy { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{ "name": "SEO-Kollektionstext", "settings": [], "presets": [{ "name": "SEO-Kollektionstext" }] }
{% endschema %}
