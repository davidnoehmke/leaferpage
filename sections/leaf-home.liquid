{% liquid
  assign primary_url = section.settings.primary_link
  assign secondary_url = section.settings.secondary_link
%}
<section class="leaf-home" aria-labelledby="leaf-home-heading">
  <div class="leaf-home__inner">
    <div class="leaf-home__hero">
      <div class="leaf-home__hero-copy">
        {% if section.settings.eyebrow != blank %}<p class="leaf-home__eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        <h1 id="leaf-home-heading">{{ section.settings.heading }}</h1>
        {% if section.settings.text != blank %}<div class="leaf-home__intro rte">{{ section.settings.text }}</div>{% endif %}
        <div class="leaf-home__actions">
          {% if section.settings.primary_label != blank and primary_url != blank %}<a class="leaf-home__button leaf-home__button--primary" href="{{ primary_url }}">{{ section.settings.primary_label }}</a>{% endif %}
          {% if section.settings.secondary_label != blank and secondary_url != blank %}<a class="leaf-home__button leaf-home__button--secondary" href="{{ secondary_url }}">{{ section.settings.secondary_label }}</a>{% endif %}
        </div>
      </div>
      {% if section.settings.image != blank %}
        <div class="leaf-home__hero-media"><img src="{{ section.settings.image | image_url: width: 1400 }}" alt="{{ section.settings.image.alt | escape }}" loading="eager" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}"></div>
      {% endif %}
    </div>
    <div class="leaf-home__grid">
      {% for block in section.blocks %}
        <article class="leaf-home__card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}<div class="leaf-home__icon" aria-hidden="true">{{ block.settings.icon }}</div>{% endif %}
          <h2>{{ block.settings.heading }}</h2>
          {% if block.settings.text != blank %}<p>{{ block.settings.text }}</p>{% endif %}
          {% if block.settings.link_label != blank and block.settings.link != blank %}<a href="{{ block.settings.link }}">{{ block.settings.link_label }} <span aria-hidden="true">→</span></a>{% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "LEAFer Startseite",
  "tag": "section",
  "class": "leaf-home-section",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"LEAFers Pflanzenpflege-System"},
    {"type":"text","id":"heading","label":"Überschrift","default":"Pflanzenpflege beginnt an der Wurzel."},
    {"type":"richtext","id":"text","label":"Einleitung","default":"<p>Finde Substrate, Gefäße und smarte Helfer, die zu deinem Pflanzenprojekt passen.</p>"},
    {"type":"image_picker","id":"image","label":"Hero-Bild"},
    {"type":"text","id":"primary_label","label":"Primärer Button","default":"Sortiment entdecken"},
    {"type":"url","id":"primary_link","label":"Primärer Link"},
    {"type":"text","id":"secondary_label","label":"Sekundärer Button","default":"Substrat konfigurieren"},
    {"type":"url","id":"secondary_link","label":"Sekundärer Link"}
  ],
  "blocks": [
    {
      "type":"card",
      "name":"Bereichskarte",
      "settings":[
        {"type":"text","id":"icon","label":"Icon/Text","default":"✦"},
        {"type":"text","id":"heading","label":"Titel","default":"Substrate"},
        {"type":"textarea","id":"text","label":"Beschreibung","default":"Strukturstabile Mischungen für unterschiedliche Wurzelräume."},
        {"type":"text","id":"link_label","label":"Linktext","default":"Bereich ansehen"},
        {"type":"url","id":"link","label":"Link"}
      ]
    }
  ],
  "presets":[{"name":"LEAFer Startseite","blocks":[{"type":"card"},{"type":"card"},{"type":"card"},{"type":"card"}]}]
}
{% endschema %}