<section class="newsletter-services">
  <div class="page-width newsletter-services__inner">
    <div class="newsletter-services__signup">
      <h2>{% if section.settings.heading != blank %}{{ section.settings.heading }}{% else %}{{ 'newsletter.heading' | t }}{% endif %}</h2>
      {% form 'customer', class: 'newsletter-services__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">{{ 'newsletter.email' | t }}</label>
        <input id="NewsletterEmail-{{ section.id }}" type="email" name="contact[email]" value="{{ form.email }}" placeholder="{{ 'newsletter.email' | t }}" autocomplete="email" required>
        <button type="submit">{{ 'newsletter.submit' | t }}</button>
        {% if form.posted_successfully? %}<p class="newsletter-services__message">{{ 'newsletter.success' | t }}</p>{% endif %}
        {% if form.errors %}<div class="newsletter-services__message">{{ form.errors | default_errors }}</div>{% endif %}
      {% endform %}
    </div>
    <div class="newsletter-services__items">
      {% for block in section.blocks %}
        {% assign service_key = 'services.' | append: block.settings.icon %}
        <div class="newsletter-services__item" {{ block.shopify_attributes }}>
          <svg viewBox="0 0 36 36" aria-hidden="true">
            {% case block.settings.icon %}
              {% when 'shipping' %}<path d="M3 10h18v14H3zM21 15h6l6 6v3H21zM9 29a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM27 29a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
              {% when 'payment' %}<path d="M5 9h26v19H5zM5 15h26M10 23h6"/>
              {% else %}<circle cx="18" cy="14" r="6"/><path d="M7 31c1-7 5-11 11-11s10 4 11 11M15 14l2 2 4-5"/>
            {% endcase %}
          </svg>
          <div>
            {% if block.settings.heading != blank %}<strong>{{ block.settings.heading }}</strong>{% else %}<strong>{{ service_key | append: '_title' | t }}</strong>{% endif %}
            {% if block.settings.text != blank %}<span>{{ block.settings.text }}</span>{% else %}<span>{{ service_key | append: '_text' | t }}</span>{% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .newsletter-services { border-top: 1px solid var(--border); background: var(--surface); }
  .newsletter-services__inner { min-height: 150px; display: grid; grid-template-columns: 1.15fr 1.5fr; gap: 4rem; align-items: center; padding-block: 2rem; }
  .newsletter-services__signup { display: grid; grid-template-columns: minmax(170px, .6fr) 1fr; gap: 1.5rem; align-items: center; }
  .newsletter-services__signup h2 { margin: 0; font-size: 1.15rem; line-height: 1.35; }
  .newsletter-services__form { display: grid; grid-template-columns: 1fr auto; }
  .newsletter-services__form input { min-width: 0; min-height: 46px; border: 1px solid var(--border); border-radius: 5px 0 0 5px; background: var(--background); padding: .7rem 1rem; }
  .newsletter-services__form button { border-radius: 0 5px 5px 0; }
  .newsletter-services__message { grid-column: 1 / -1; margin: .5rem 0 0; font-size: .8rem; }
  .newsletter-services__items { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .newsletter-services__item { display: flex; align-items: center; gap: .7rem; }
  .newsletter-services__item svg { width: 32px; flex: 0 0 auto; fill: none; stroke: currentColor; stroke-width: 1.3; stroke-linecap: round; stroke-linejoin: round; }
  .newsletter-services__item strong, .newsletter-services__item span { display: block; }
  .newsletter-services__item strong { font-size: .8rem; }
  .newsletter-services__item span { color: var(--muted); font-size: .68rem; }
  @media (max-width: 1050px) { .newsletter-services__inner { grid-template-columns: 1fr; gap: 2rem; } }
  @media (max-width: 650px) { .newsletter-services__signup { grid-template-columns: 1fr; } .newsletter-services__items { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "settings": [{ "type": "text", "id": "heading", "label": "t:sections.newsletter.heading" }],
  "blocks": [
    {
      "type": "service",
      "name": "t:sections.newsletter.service",
      "settings": [
        { "type": "select", "id": "icon", "label": "t:sections.newsletter.icon", "options": [
          { "value": "shipping", "label": "t:options.shipping" },
          { "value": "payment", "label": "t:options.payment" },
          { "value": "support", "label": "t:options.support" }
        ], "default": "shipping" },
        { "type": "text", "id": "heading", "label": "t:sections.newsletter.service_heading" },
        { "type": "text", "id": "text", "label": "t:sections.newsletter.service_text" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [{ "name": "t:sections.newsletter.name", "blocks": [{ "type": "service" }, { "type": "service" }, { "type": "service" }] }]
}
{% endschema %}
