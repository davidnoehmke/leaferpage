{% liquid
  assign announcement_text = section.settings.text
  if announcement_text == blank
    assign announcement_text = 'announcement.text' | t
  endif
%}
<aside class="announcement" aria-label="{{ 'announcement.label' | t }}">
  {% if section.settings.link != blank %}<a href="{{ section.settings.link }}">{% endif %}
    <span>{{ announcement_text }}</span>
    {% if section.settings.link != blank %}<span aria-hidden="true">→</span>{% endif %}
  {% if section.settings.link != blank %}</a>{% endif %}
</aside>

{% stylesheet %}
  .announcement { min-height: 34px; display: grid; place-items: center; padding: .35rem 1rem; background: var(--accent); color: #fff; font-size: .72rem; font-weight: 750; letter-spacing: .025em; text-align: center; }
  .announcement a { display: inline-flex; align-items: center; gap: .65rem; color: inherit; text-decoration: none; }
  .announcement a:hover { opacity: .86; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.announcement.name",
  "settings": [
    { "type": "text", "id": "text", "label": "t:sections.announcement.text" },
    { "type": "url", "id": "link", "label": "t:sections.announcement.link" }
  ]
}
{% endschema %}
