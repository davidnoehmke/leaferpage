{% comment %}
  LEAFerservice – Scrolling Startseite mit festem Hintergrund
  Datei: sections/leafer-scroll-shop.liquid

  Standard-Reihenfolge:
  1. Gemischte Substrate
  2. Substratbestandteile
  3. Pflanzgefäße
  4. Bundles & Sets
  5. Sale

  Die Collections werden im Theme-Editor ausgewählt.
  Produkt- und Collection-Metafelder können über Namespace/Keys verknüpft werden.
{% endcomment %}

{%- liquid
  assign product_namespace = section.settings.product_namespace | strip
  assign product_badge_key = section.settings.product_badge_key | strip
  assign product_subtitle_key = section.settings.product_subtitle_key | strip
  assign product_usp_key = section.settings.product_usp_key | strip

  assign collection_namespace = section.settings.collection_namespace | strip
  assign collection_heading_key = section.settings.collection_heading_key | strip
  assign collection_text_key = section.settings.collection_text_key | strip
-%}

<section
  id="LeafScrollShop-{{ section.id }}"
  class="lss"
  style="
    --lss-text: {{ section.settings.text_color }};
    --lss-muted: {{ section.settings.muted_color }};
    --lss-green: {{ section.settings.green }};
    --lss-dark: {{ section.settings.dark_green }};
    --lss-accent: {{ section.settings.accent }};
    --lss-border: {{ section.settings.border_color }};
    --lss-page-width: {{ section.settings.page_width }}px;
    --lss-radius: {{ section.settings.radius }}px;
    --lss-row-gap: {{ section.settings.row_gap }}px;
    --lss-panel-alpha: {{ section.settings.panel_opacity | divided_by: 100.0 }};
    --lss-card-alpha: {{ section.settings.card_opacity | divided_by: 100.0 }};
    --lss-blur: {{ section.settings.blur }}px;
  "
>
  <div class="lss__background" aria-hidden="true">
    <div class="lss__background-media">
      {%- if section.settings.background_image != blank -%}
        {{
          section.settings.background_image
          | image_url: width: 2400
          | image_tag:
            widths: '900, 1300, 1800, 2400',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'lss__background-image lss__background-image--desktop',
            alt: ''
        }}
      {%- endif -%}

      {%- if section.settings.background_image_mobile != blank -%}
        {{
          section.settings.background_image_mobile
          | image_url: width: 1200
          | image_tag:
            widths: '500, 750, 1000, 1200',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'lss__background-image lss__background-image--mobile',
            alt: ''
        }}
      {%- endif -%}
    </div>

    <div class="lss__background-overlay"></div>
    <div class="lss__orb lss__orb--one"></div>
    <div class="lss__orb lss__orb--two"></div>
    <div class="lss__grain"></div>
  </div>

  <div class="lss__content">
    <div class="lss__shell">
      <header class="lss__intro lss-glass">
        {%- if section.settings.eyebrow != blank -%}
          <p class="lss__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.intro != blank -%}
          <div class="lss__intro-text rte">{{ section.settings.intro }}</div>
        {%- endif -%}

        {%- if section.settings.show_anchor_navigation and section.blocks.size > 0 -%}
          <nav class="lss__anchors" aria-label="Sortimentsbereiche">
            {%- for block in section.blocks -%}
              {%- assign anchor_title = block.settings.heading -%}
              {%- if anchor_title == blank and block.settings.collection != blank -%}
                {%- assign anchor_title = block.settings.collection.title -%}
              {%- endif -%}
              <a href="#LeafScrollBlock-{{ block.id }}">
                {{ anchor_title | default: 'Collection' }}
              </a>
            {%- endfor -%}
          </nav>
        {%- endif -%}
      </header>

      <div class="lss__worlds">
        {%- for block in section.blocks -%}
          {%- liquid
            assign collection = block.settings.collection
            assign heading = block.settings.heading
            assign text_value = block.settings.text

            if block.settings.prefer_collection_metafields and collection != blank
              if collection_namespace != blank and collection_heading_key != blank
                assign collection_heading_meta = collection.metafields[collection_namespace][collection_heading_key]
                if collection_heading_meta != blank
                  assign heading = collection_heading_meta.value
                endif
              endif

              if collection_namespace != blank and collection_text_key != blank
                assign collection_text_meta = collection.metafields[collection_namespace][collection_text_key]
                if collection_text_meta != blank
                  assign text_value = collection_text_meta
                endif
              endif
            endif

            if heading == blank and collection != blank
              assign heading = collection.title
            endif
          -%}

          <section
            id="LeafScrollBlock-{{ block.id }}"
            class="lss__world lss__world--{{ block.settings.tone }} lss-glass"
            {{ block.shopify_attributes }}
          >
            <header class="lss__world-head">
              <div class="lss__world-copy">
                <div class="lss__meta">
                  {%- if block.settings.badge != blank -%}
                    <span class="lss__badge">{{ block.settings.badge }}</span>
                  {%- endif -%}

                  {%- if block.settings.eyebrow != blank -%}
                    <span class="lss__kicker">{{ block.settings.eyebrow }}</span>
                  {%- endif -%}
                </div>

                {%- if heading != blank -%}
                  <h3>{{ heading }}</h3>
                {%- endif -%}

                {%- if text_value != blank -%}
                  <div class="lss__world-text rte">
                    {%- if text_value.type != blank -%}
                      {{ text_value | metafield_tag }}
                    {%- else -%}
                      {{ text_value }}
                    {%- endif -%}
                  </div>
                {%- elsif collection.description != blank -%}
                  <div class="lss__world-text rte">
                    {{ collection.description | strip_html | truncatewords: 34 }}
                  </div>
                {%- endif -%}
              </div>

              {%- if collection != blank and block.settings.show_view_all -%}
                <a class="lss__view-all" href="{{ collection.url }}">
                  {{ block.settings.view_all_label }}
                  <span aria-hidden="true">→</span>
                </a>
              {%- endif -%}
            </header>

            {%- if collection != blank -%}
              <div
                class="lss__products{% if section.settings.mobile_slider %} lss__products--slider{% endif %}"
                style="--lss-columns: {{ block.settings.columns_desktop }};"
                role="list"
                aria-label="{{ heading | escape }}"
              >
                {%- for product in collection.products limit: block.settings.products_to_show -%}
                  {%- liquid
                    assign variant = product.selected_or_first_available_variant

                    assign product_badge = blank
                    if product_namespace != blank and product_badge_key != blank
                      assign product_badge = product.metafields[product_namespace][product_badge_key]
                    endif
                    if product_badge == blank
                      assign product_badge = product.metafields.custom.badge
                    endif

                    assign product_subtitle = blank
                    if product_namespace != blank and product_subtitle_key != blank
                      assign product_subtitle = product.metafields[product_namespace][product_subtitle_key]
                    endif
                    if product_subtitle == blank
                      assign product_subtitle = product.metafields.custom.short_description
                    endif
                    if product_subtitle == blank
                      assign product_subtitle = product.metafields.custom.subtitle
                    endif

                    assign product_usp = blank
                    if product_namespace != blank and product_usp_key != blank
                      assign product_usp = product.metafields[product_namespace][product_usp_key]
                    endif
                    if product_usp == blank
                      assign product_usp = product.metafields.custom.usp
                    endif
                  -%}

                  <article class="lss-card" role="listitem">
                    <a
                      class="lss-card__media lss-card__media--{{ block.settings.image_ratio }}"
                      href="{{ product.url }}"
                      aria-label="{{ product.title | escape }}"
                    >
                      {%- if product.featured_media != blank -%}
                        {{
                          product.featured_media.preview_image
                          | image_url: width: 1000
                          | image_tag:
                            widths: '240, 360, 480, 640, 800, 1000',
                            sizes: '(min-width: 990px) 25vw, 50vw',
                            loading: 'lazy',
                            alt: product.featured_media.alt | default: product.title
                        }}
                      {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag: 'lss-card__placeholder' }}
                      {%- endif -%}

                      {%- if product_badge != blank -%}
                        <span class="lss-card__badge">{{ product_badge | metafield_text }}</span>
                      {%- elsif product.compare_at_price_max > product.price -%}
                        <span class="lss-card__badge">Sale</span>
                      {%- endif -%}
                    </a>

                    <div class="lss-card__body">
                      {%- if section.settings.show_vendor and product.vendor != blank -%}
                        <div class="lss-card__vendor">{{ product.vendor }}</div>
                      {%- endif -%}

                      <h4>
                        <a href="{{ product.url }}">{{ product.title }}</a>
                      </h4>

                      {%- if product_subtitle != blank -%}
                        <div class="lss-card__subtitle">
                          {{ product_subtitle | metafield_text | truncate: 105 }}
                        </div>
                      {%- elsif product_usp != blank -%}
                        <div class="lss-card__subtitle">
                          {{ product_usp | metafield_text | truncate: 105 }}
                        </div>
                      {%- endif -%}

                      <div class="lss-card__bottom">
                        <div class="lss-card__price">
                          {%- if product.price_varies -%}
                            <span>ab {{ product.price_min | money }}</span>
                          {%- else -%}
                            <span>{{ product.price | money }}</span>
                          {%- endif -%}

                          {%- if variant.compare_at_price > variant.price -%}
                            <s>{{ variant.compare_at_price | money }}</s>
                          {%- endif -%}
                        </div>

                        {%- if section.settings.quick_add and variant != blank -%}
                          {%- if product.has_only_default_variant -%}
                            {%- assign form_id = 'LeafScrollForm-' | append: section.id | append: '-' | append: block.id | append: '-' | append: product.id -%}
                            {%- form 'product', product, id: form_id, class: 'lss-card__form' -%}
                              <input type="hidden" name="id" value="{{ variant.id }}">
                              <button
                                type="submit"
                                name="add"
                                class="lss-card__add"
                                aria-label="{{ product.title | escape }} in den Warenkorb legen"
                                {% unless variant.available %}disabled{% endunless %}
                              >
                                {%- if variant.available -%}+{%- else -%}×{%- endif -%}
                              </button>
                            {%- endform -%}
                          {%- else -%}
                            <a
                              class="lss-card__add"
                              href="{{ product.url }}"
                              aria-label="Varianten von {{ product.title | escape }} auswählen"
                            >→</a>
                          {%- endif -%}
                        {%- endif -%}
                      </div>
                    </div>
                  </article>
                {%- else -%}
                  {%- for i in (1..4) -%}
                    <article class="lss-card" role="listitem">
                      <div class="lss-card__media lss-card__media--square">
                        {{ 'product-' | append: i | placeholder_svg_tag: 'lss-card__placeholder' }}
                      </div>
                      <div class="lss-card__body">
                        <h4>Beispielprodukt</h4>
                        <div class="lss-card__price"><span>0,00 €</span></div>
                      </div>
                    </article>
                  {%- endfor -%}
                {%- endfor -%}
              </div>

              {%- if block.settings.show_mobile_button -%}
                <a class="lss__mobile-button" href="{{ collection.url }}">
                  {{ block.settings.view_all_label }}
                  <span aria-hidden="true">→</span>
                </a>
              {%- endif -%}
            {%- else -%}
              <div class="lss__empty">
                <strong>{{ heading | default: 'Collection auswählen' }}</strong>
                <span>Wähle in diesem Block die passende Shopify-Collection aus.</span>
              </div>
            {%- endif -%}
          </section>
        {%- else -%}
          <div class="lss__empty lss-glass">
            <strong>Noch keine Sortimentsbereiche vorhanden.</strong>
            <span>Füge Collection-Blöcke im Theme-Editor hinzu.</span>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #LeafScrollShop-{{ section.id }} {
    position: relative;
    isolation: isolate;
    overflow: clip;
    color: var(--lss-text);
  }

  #LeafScrollShop-{{ section.id }} *,
  #LeafScrollShop-{{ section.id }} *::before,
  #LeafScrollShop-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #LeafScrollShop-{{ section.id }} a {
    color: inherit;
    text-decoration: none;
  }

  #LeafScrollShop-{{ section.id }} .lss__background {
    position: sticky;
    top: 0;
    z-index: 0;
    height: 100svh;
    margin-bottom: -100svh;
    overflow: hidden;
    background:
      radial-gradient(circle at 16% 18%, rgba(217, 180, 61, .28), transparent 32%),
      radial-gradient(circle at 82% 30%, rgba(46, 91, 59, .28), transparent 36%),
      linear-gradient(145deg, #e7e0ca 0%, #f7f3e7 42%, #ccd9c8 100%);
  }

  #LeafScrollShop-{{ section.id }} .lss__background-media,
  #LeafScrollShop-{{ section.id }} .lss__background-overlay,
  #LeafScrollShop-{{ section.id }} .lss__grain {
    position: absolute;
    inset: 0;
  }

  #LeafScrollShop-{{ section.id }} .lss__background-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: {{ section.settings.background_position }};
    animation: lssBackgroundBreath-{{ section.id }} 28s ease-in-out infinite alternate;
  }

  #LeafScrollShop-{{ section.id }} .lss__background-image--mobile {
    display: none;
  }

  #LeafScrollShop-{{ section.id }} .lss__background-overlay {
    background:
      linear-gradient(
        180deg,
        rgba(247, 244, 235, {{ section.settings.overlay_opacity | divided_by: 100.0 }}),
        rgba(232, 228, 214, {{ section.settings.overlay_opacity | minus: 10 | at_least: 0 | divided_by: 100.0 }})
      );
  }

  #LeafScrollShop-{{ section.id }} .lss__grain {
    opacity: .16;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.18'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
  }

  #LeafScrollShop-{{ section.id }} .lss__orb {
    position: absolute;
    width: min(46vw, 620px);
    aspect-ratio: 1;
    border-radius: 50%;
    filter: blur(65px);
    opacity: .22;
    animation: lssOrbMove-{{ section.id }} 18s ease-in-out infinite alternate;
  }

  #LeafScrollShop-{{ section.id }} .lss__orb--one {
    top: -18%;
    left: -12%;
    background: var(--lss-accent);
  }

  #LeafScrollShop-{{ section.id }} .lss__orb--two {
    right: -14%;
    bottom: -20%;
    background: var(--lss-green);
    animation-delay: -8s;
  }

  #LeafScrollShop-{{ section.id }} .lss__content {
    position: relative;
    z-index: 1;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #LeafScrollShop-{{ section.id }} .lss__shell {
    width: min(calc(100% - 40px), var(--lss-page-width));
    margin-inline: auto;
  }

  #LeafScrollShop-{{ section.id }} .lss-glass {
    background: rgba(255, 255, 255, var(--lss-panel-alpha));
    border: 1px solid rgba(255, 255, 255, .58);
    box-shadow: 0 24px 70px rgba(23, 52, 34, .11);
    backdrop-filter: blur(var(--lss-blur)) saturate(1.12);
    -webkit-backdrop-filter: blur(var(--lss-blur)) saturate(1.12);
  }

  #LeafScrollShop-{{ section.id }} .lss__intro {
    max-width: 960px;
    margin: 0 auto clamp(52px, 7vw, 96px);
    padding: clamp(28px, 5vw, 64px);
    border-radius: calc(var(--lss-radius) + 12px);
    text-align: center;
  }

  #LeafScrollShop-{{ section.id }} .lss__eyebrow,
  #LeafScrollShop-{{ section.id }} .lss__kicker {
    color: var(--lss-green);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: .15em;
    text-transform: uppercase;
  }

  #LeafScrollShop-{{ section.id }} .lss__eyebrow {
    margin: 0 0 13px;
  }

  #LeafScrollShop-{{ section.id }} .lss__intro h2 {
    margin: 0;
    color: var(--lss-text);
    font-size: clamp(38px, 6vw, 68px);
    line-height: 1;
    letter-spacing: -.04em;
    text-wrap: balance;
  }

  #LeafScrollShop-{{ section.id }} .lss__intro-text {
    max-width: 700px;
    margin: 19px auto 0;
    color: var(--lss-muted);
    font-size: 17px;
    line-height: 1.7;
  }

  #LeafScrollShop-{{ section.id }} .lss__intro-text > *:last-child,
  #LeafScrollShop-{{ section.id }} .lss__world-text > *:last-child {
    margin-bottom: 0;
  }

  #LeafScrollShop-{{ section.id }} .lss__anchors {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 9px;
    margin-top: 30px;
  }

  #LeafScrollShop-{{ section.id }} .lss__anchors a {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 8px 15px;
    border: 1px solid rgba(46, 91, 59, .2);
    border-radius: 999px;
    background: rgba(255, 255, 255, .38);
    color: var(--lss-dark);
    font-size: 13px;
    font-weight: 750;
    backdrop-filter: blur(10px);
  }

  #LeafScrollShop-{{ section.id }} .lss__worlds {
    display: grid;
    gap: var(--lss-row-gap);
  }

  #LeafScrollShop-{{ section.id }} .lss__world {
    padding: clamp(26px, 4vw, 54px);
    border-radius: calc(var(--lss-radius) + 10px);
    scroll-margin-top: 110px;
  }

  #LeafScrollShop-{{ section.id }} .lss__world--dark {
    background: rgba(23, 52, 34, .70);
    border-color: rgba(255, 255, 255, .2);
  }

  #LeafScrollShop-{{ section.id }} .lss__world--sale {
    background:
      linear-gradient(135deg, rgba(217, 180, 61, .24), rgba(255, 255, 255, var(--lss-panel-alpha)));
  }

  #LeafScrollShop-{{ section.id }} .lss__world-head {
    display: flex;
    justify-content: space-between;
    gap: 32px;
    align-items: flex-end;
    margin-bottom: 27px;
  }

  #LeafScrollShop-{{ section.id }} .lss__world-copy {
    max-width: 760px;
  }

  #LeafScrollShop-{{ section.id }} .lss__meta {
    min-height: 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
  }

  #LeafScrollShop-{{ section.id }} .lss__badge,
  #LeafScrollShop-{{ section.id }} .lss-card__badge {
    display: inline-flex;
    align-items: center;
    padding: 6px 10px;
    border-radius: 999px;
    background: var(--lss-accent);
    color: var(--lss-dark);
    font-size: 10px;
    font-weight: 850;
    letter-spacing: .06em;
    text-transform: uppercase;
  }

  #LeafScrollShop-{{ section.id }} .lss__world h3 {
    margin: 0;
    color: var(--lss-text);
    font-size: clamp(30px, 4vw, 46px);
    line-height: 1.04;
    letter-spacing: -.03em;
    text-wrap: balance;
  }

  #LeafScrollShop-{{ section.id }} .lss__world-text {
    max-width: 690px;
    margin-top: 12px;
    color: var(--lss-muted);
    font-size: 15px;
    line-height: 1.7;
  }

  #LeafScrollShop-{{ section.id }} .lss__world--dark h3,
  #LeafScrollShop-{{ section.id }} .lss__world--dark .lss__kicker,
  #LeafScrollShop-{{ section.id }} .lss__world--dark .lss__world-text,
  #LeafScrollShop-{{ section.id }} .lss__world--dark .lss__view-all {
    color: #fff;
  }

  #LeafScrollShop-{{ section.id }} .lss__world--dark .lss__world-text {
    color: rgba(255, 255, 255, .72);
  }

  #LeafScrollShop-{{ section.id }} .lss__view-all {
    flex: 0 0 auto;
    display: inline-flex;
    gap: 8px;
    align-items: center;
    padding: 10px 0;
    color: var(--lss-green);
    font-size: 14px;
    font-weight: 800;
  }

  #LeafScrollShop-{{ section.id }} .lss__products {
    display: grid;
    grid-template-columns: repeat(var(--lss-columns), minmax(0, 1fr));
    gap: clamp(12px, 2vw, 22px);
  }

  #LeafScrollShop-{{ section.id }} .lss-card {
    min-width: 0;
    overflow: hidden;
    background: rgba(255, 255, 255, var(--lss-card-alpha));
    border: 1px solid rgba(255, 255, 255, .66);
    border-radius: var(--lss-radius);
    box-shadow: 0 12px 34px rgba(23, 52, 34, .09);
    backdrop-filter: blur(var(--lss-blur)) saturate(1.12);
    -webkit-backdrop-filter: blur(var(--lss-blur)) saturate(1.12);
    transition: transform .25s ease, box-shadow .25s ease, background .25s ease;
  }

  #LeafScrollShop-{{ section.id }} .lss-card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, min(1, calc(var(--lss-card-alpha) + .13)));
    box-shadow: 0 22px 52px rgba(23, 52, 34, .15);
  }

  #LeafScrollShop-{{ section.id }} .lss-card__media {
    position: relative;
    display: block;
    overflow: hidden;
    background: rgba(255, 255, 255, .34);
  }

  #LeafScrollShop-{{ section.id }} .lss-card__media--square { aspect-ratio: 1 / 1; }
  #LeafScrollShop-{{ section.id }} .lss-card__media--portrait { aspect-ratio: 4 / 5; }
  #LeafScrollShop-{{ section.id }} .lss-card__media--landscape { aspect-ratio: 4 / 3; }

  #LeafScrollShop-{{ section.id }} .lss-card__media img,
  #LeafScrollShop-{{ section.id }} .lss-card__placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform .55s ease;
  }

  #LeafScrollShop-{{ section.id }} .lss-card:hover .lss-card__media img {
    transform: scale(1.035);
  }

  #LeafScrollShop-{{ section.id }} .lss-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
  }

  #LeafScrollShop-{{ section.id }} .lss-card__body {
    padding: 17px;
  }

  #LeafScrollShop-{{ section.id }} .lss-card__vendor {
    margin-bottom: 7px;
    color: var(--lss-muted);
    font-size: 10px;
    font-weight: 750;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  #LeafScrollShop-{{ section.id }} .lss-card h4 {
    min-height: 2.7em;
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: var(--lss-text);
    font-size: 15px;
    line-height: 1.35;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  #LeafScrollShop-{{ section.id }} .lss-card__subtitle {
    min-height: 38px;
    margin-top: 7px;
    overflow: hidden;
    color: var(--lss-muted);
    font-size: 12px;
    line-height: 1.55;
  }

  #LeafScrollShop-{{ section.id }} .lss-card__bottom {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-end;
    margin-top: 15px;
  }

  #LeafScrollShop-{{ section.id }} .lss-card__price {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    align-items: baseline;
    color: var(--lss-dark);
    font-size: 15px;
    font-weight: 850;
  }

  #LeafScrollShop-{{ section.id }} .lss-card__price s {
    color: var(--lss-muted);
    font-size: 11px;
    font-weight: 500;
  }

  #LeafScrollShop-{{ section.id }} .lss-card__form {
    margin: 0;
  }

  #LeafScrollShop-{{ section.id }} .lss-card__add {
    flex: 0 0 36px;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border: 0;
    border-radius: 50%;
    background: var(--lss-green);
    color: #fff;
    font: inherit;
    font-size: 20px;
    cursor: pointer;
    transition: transform .2s ease, background .2s ease;
  }

  #LeafScrollShop-{{ section.id }} .lss-card__add:hover {
    transform: scale(1.06);
    background: var(--lss-dark);
  }

  #LeafScrollShop-{{ section.id }} .lss-card__add[disabled] {
    opacity: .4;
    cursor: not-allowed;
  }

  #LeafScrollShop-{{ section.id }} .lss__mobile-button {
    display: none;
  }

  #LeafScrollShop-{{ section.id }} .lss__empty {
    display: grid;
    gap: 5px;
    padding: 28px;
    border: 1px dashed rgba(46, 91, 59, .3);
    border-radius: var(--lss-radius);
    color: var(--lss-muted);
    text-align: center;
  }

  #LeafScrollShop-{{ section.id }} .lss__empty strong {
    color: var(--lss-text);
  }

  #LeafScrollShop-{{ section.id }} :focus-visible {
    outline: 3px solid var(--lss-accent);
    outline-offset: 4px;
  }

  @keyframes lssBackgroundBreath-{{ section.id }} {
    from { transform: scale(1.02) translate3d(-.4%, -.2%, 0); }
    to { transform: scale(1.09) translate3d(.6%, .4%, 0); }
  }

  @keyframes lssOrbMove-{{ section.id }} {
    from { transform: translate3d(-2%, -2%, 0) scale(.95); }
    to { transform: translate3d(8%, 6%, 0) scale(1.08); }
  }

  @media screen and (max-width: 989px) {
    #LeafScrollShop-{{ section.id }} .lss__products {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    #LeafScrollShop-{{ section.id }} .lss__background-image--mobile {
      display: block;
    }

    #LeafScrollShop-{{ section.id }} .lss__background-image--desktop:has(+ .lss__background-image--mobile) {
      display: none;
    }

    #LeafScrollShop-{{ section.id }} .lss__content {
      padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px;
    }

    #LeafScrollShop-{{ section.id }} .lss__shell {
      width: min(calc(100% - 28px), var(--lss-page-width));
    }

    #LeafScrollShop-{{ section.id }} .lss__intro {
      padding: 28px 20px;
      text-align: left;
    }

    #LeafScrollShop-{{ section.id }} .lss__intro h2 {
      font-size: clamp(34px, 10vw, 48px);
    }

    #LeafScrollShop-{{ section.id }} .lss__intro-text {
      margin-inline: 0;
      font-size: 15px;
    }

    #LeafScrollShop-{{ section.id }} .lss__anchors {
      justify-content: flex-start;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 3px;
      scrollbar-width: none;
    }

    #LeafScrollShop-{{ section.id }} .lss__anchors::-webkit-scrollbar {
      display: none;
    }

    #LeafScrollShop-{{ section.id }} .lss__anchors a {
      flex: 0 0 auto;
    }

    #LeafScrollShop-{{ section.id }} .lss__world {
      margin-inline: -6px;
      padding: 26px 20px;
      border-radius: calc(var(--lss-radius) + 4px);
    }

    #LeafScrollShop-{{ section.id }} .lss__world-head {
      align-items: flex-start;
      margin-bottom: 20px;
    }

    #LeafScrollShop-{{ section.id }} .lss__world h3 {
      font-size: clamp(29px, 9vw, 39px);
    }

    #LeafScrollShop-{{ section.id }} .lss__view-all {
      display: none;
    }

    #LeafScrollShop-{{ section.id }} .lss__products {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    #LeafScrollShop-{{ section.id }} .lss__products--slider {
      width: calc(100vw - 34px);
      display: flex;
      gap: 10px;
      overflow-x: auto;
      padding-right: 14px;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    #LeafScrollShop-{{ section.id }} .lss__products--slider::-webkit-scrollbar {
      display: none;
    }

    #LeafScrollShop-{{ section.id }} .lss__products--slider .lss-card {
      flex: 0 0 min(72vw, 285px);
      scroll-snap-align: start;
    }

    #LeafScrollShop-{{ section.id }} .lss-card__body {
      padding: 13px;
    }

    #LeafScrollShop-{{ section.id }} .lss-card h4 {
      font-size: 14px;
    }

    #LeafScrollShop-{{ section.id }} .lss-card__subtitle {
      min-height: 34px;
      font-size: 11px;
    }

    #LeafScrollShop-{{ section.id }} .lss-card__add {
      flex-basis: 32px;
      width: 32px;
      height: 32px;
      font-size: 18px;
    }

    #LeafScrollShop-{{ section.id }} .lss__mobile-button {
      min-height: 46px;
      display: flex;
      justify-content: center;
      gap: 8px;
      align-items: center;
      margin-top: 18px;
      border: 1px solid rgba(46, 91, 59, .45);
      border-radius: 999px;
      background: rgba(255, 255, 255, .25);
      color: var(--lss-green);
      font-size: 13px;
      font-weight: 800;
      backdrop-filter: blur(10px);
    }

    #LeafScrollShop-{{ section.id }} .lss__world--dark .lss__mobile-button {
      border-color: rgba(255, 255, 255, .45);
      color: #fff;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #LeafScrollShop-{{ section.id }} *,
    #LeafScrollShop-{{ section.id }} *::before,
    #LeafScrollShop-{{ section.id }} *::after {
      animation-duration: .01ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: .01ms !important;
    }
  }
</style>

