{% liquid
  assign recommendations = product.metafields.leafer.cross_selling.value
  assign fallback_collection = section.settings.collection | default: collections.all
%}
{% if recommendations != blank or fallback_collection != blank %}
  <section class="product-cross-sell page-width" aria-labelledby="CrossSell-{{ section.id }}">
    <header>
      <p>{{ 'cross_sell.eyebrow' | t }}</p>
      <h2 id="CrossSell-{{ section.id }}">{% if section.settings.heading != blank %}{{ section.settings.heading }}{% else %}{{ 'cross_sell.heading' | t }}{% endif %}</h2>
    </header>
    <div class="product-cross-sell__grid">
      {% if recommendations != blank %}
        {% for recommendation in recommendations limit: 4 %}{% render 'product-card', product: recommendation, compact: true %}{% endfor %}
      {% else %}
        {% for recommendation in fallback_collection.products limit: 4 %}
          {% unless recommendation.id == product.id %}{% render 'product-card', product: recommendation, compact: true %}{% endunless %}
        {% endfor %}
      {% endif %}
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .product-cross-sell { margin-block: var(--space-section); }
  .product-cross-sell header { max-width: 720px; margin-bottom: 2rem; }
  .product-cross-sell header p { margin: 0 0 .5rem; color: var(--accent); font-size: .75rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
  .product-cross-sell h2 { margin: 0; font-size: clamp(2.2rem, 5vw, 4.5rem); line-height: .98; letter-spacing: -.05em; }
  .product-cross-sell__grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; }
  @media (max-width: 900px) { .product-cross-sell__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
{% endstylesheet %}

{% schema %}
{
  "name": "Cross-Selling",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Passt perfekt dazu" },
    { "type": "collection", "id": "collection", "label": "Fallback-Kollektion" }
  ],
  "presets": [{ "name": "Cross-Selling" }]
}
{% endschema %}
