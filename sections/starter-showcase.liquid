<section class="starter-showcase page-width">
  <div class="starter-showcase__inner">
    <div class="starter-showcase__intro">
      <h2>{% if section.settings.heading != blank %}{{ section.settings.heading }}{% else %}{{ 'starter.heading' | t }}{% endif %}</h2>
      {% if section.settings.text != blank %}<div class="starter-showcase__text">{{ section.settings.text }}</div>{% else %}<p>{{ 'starter.text' | t }}</p>{% endif %}
      {% if section.settings.link != blank %}<a class="button button--secondary" href="{{ section.settings.link }}">{% if section.settings.link_label != blank %}{{ section.settings.link_label }}{% else %}{{ 'general.discover' | t }}{% endif %}</a>{% endif %}
    </div>
    <div class="starter-showcase__cards">
      {% for block in section.blocks %}
        {% assign card_key = 'starter.' | append: block.settings.type %}
        <a href="{{ block.settings.link | default: routes.collections_url }}" class="starter-showcase__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 760 | image_tag: widths: '320, 520, 760', loading: 'lazy' }}{% else %}<span class="starter-showcase__fallback"></span>{% endif %}
          <span class="starter-showcase__shade"></span>
          <strong>{% if block.settings.title != blank %}{{ block.settings.title }}{% else %}{{ card_key | t }}{% endif %}</strong>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .starter-showcase { padding-bottom: clamp(3rem, 6vw, 5rem); }
  .starter-showcase__inner { padding: 1.2rem; border-radius: var(--radius); display: grid; grid-template-columns: minmax(260px, .85fr) 2fr; gap: 1.2rem; background: var(--surface); }
  .starter-showcase__intro { padding: clamp(1rem, 3vw, 2.4rem); align-self: center; }
  .starter-showcase__intro h2 { margin: 0 0 .7rem; font-size: clamp(1.8rem, 3vw, 2.5rem); line-height: 1.08; }
  .starter-showcase__intro p { color: var(--muted); }
  .starter-showcase__text > *:first-child { margin-top: 0; }
  .starter-showcase__text > *:last-child { margin-bottom: 0; }
  .starter-showcase__intro .button { margin-top: 1rem; }
  .starter-showcase__intro .button--secondary { border-color: color-mix(in srgb, var(--text), transparent 35%); background: transparent; color: var(--text); }
  .starter-showcase__cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: .65rem; }
  .starter-showcase__card { position: relative; min-height: 185px; border-radius: var(--radius); overflow: hidden; color: #fff; text-decoration: none; }
  .starter-showcase__card img, .starter-showcase__fallback, .starter-showcase__shade { position: absolute; inset: 0; width: 100%; height: 100%; }
  .starter-showcase__card img { object-fit: cover; transition: transform .35s ease; }
  .starter-showcase__card:hover img { transform: scale(1.04); }
  .starter-showcase__fallback { background: radial-gradient(circle at 35% 30%, #7f9468, transparent 25%), linear-gradient(145deg, #354a29, #152414); }
  .starter-showcase__shade { background: linear-gradient(0deg, rgba(0,0,0,.72), transparent 60%); }
  .starter-showcase__card strong { position: absolute; left: 1rem; right: 1rem; bottom: .9rem; font-family: var(--heading-font); font-size: 1.12rem; text-align: center; }
  @media (max-width: 1050px) { .starter-showcase__inner { grid-template-columns: 1fr; } }
  @media (max-width: 700px) { .starter-showcase__cards { grid-template-columns: repeat(2, 1fr); } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.starter_showcase.name",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.starter_showcase.heading" },
    { "type": "richtext", "id": "text", "label": "t:sections.starter_showcase.text" },
    { "type": "text", "id": "link_label", "label": "t:sections.starter_showcase.link_label" },
    { "type": "url", "id": "link", "label": "t:sections.starter_showcase.link" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "t:sections.starter_showcase.category",
      "settings": [
        { "type": "select", "id": "type", "label": "t:sections.starter_showcase.type", "options": [
          { "value": "herbs", "label": "t:options.herbs" },
          { "value": "houseplants", "label": "t:options.houseplants" },
          { "value": "vegetables", "label": "t:options.vegetables" },
          { "value": "exotics", "label": "t:options.exotics" }
        ], "default": "herbs" },
        { "type": "text", "id": "title", "label": "t:sections.starter_showcase.title" },
        { "type": "image_picker", "id": "image", "label": "t:sections.starter_showcase.image" },
        { "type": "url", "id": "link", "label": "t:sections.starter_showcase.card_link" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "t:sections.starter_showcase.name", "blocks": [{ "type": "category" }, { "type": "category" }, { "type": "category" }, { "type": "category" }] }]
}
{% endschema %}
