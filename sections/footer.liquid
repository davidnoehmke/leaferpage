{% assign current_year = 'now' | date: '%Y' %}
<footer class="site-footer">
  <div class="page-width site-footer__inner">
    <div class="site-footer__brand">
      <strong>{{ shop.name }}</strong>
      {% if section.settings.text != blank %}<div class="site-footer__text">{{ section.settings.text }}</div>{% else %}<p>{{ 'footer.text' | t }}</p>{% endif %}
    </div>
    {% if section.settings.menu != blank %}
      <nav aria-label="{{ 'accessibility.footer_menu' | t }}">{% for link in section.settings.menu.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}</nav>
    {% endif %}
    <small>{{ 'footer.copyright' | t: year: current_year, shop: shop.name }}</small>
  </div>
</footer>

{% stylesheet %}
  .site-footer { border-top: 1px solid var(--border); background: var(--surface); }
  .site-footer__inner { padding-block: 2rem; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start; }
  .site-footer__brand > strong { font-family: var(--heading-font); font-size: 1.2rem; }
  .site-footer__brand p { margin: .4rem 0 0; color: var(--muted); font-size: .82rem; }
  .site-footer__text > *:first-child { margin-top: .4rem; }
  .site-footer__text > *:last-child { margin-bottom: 0; }
  .site-footer nav { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 1rem 1.5rem; }
  .site-footer a { font-size: .8rem; text-decoration: none; }
  .site-footer small { grid-column: 1 / -1; color: var(--muted); }
  @media (max-width: 640px) { .site-footer__inner { grid-template-columns: 1fr; } .site-footer nav { justify-content: flex-start; } .site-footer small { grid-column: auto; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "t:sections.footer.menu", "default": "footer" },
    { "type": "richtext", "id": "text", "label": "t:sections.footer.text" }
  ]
}
{% endschema %}
