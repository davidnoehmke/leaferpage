<section class="community page-width">
  <div class="community__intro">
    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".8" fill="currentColor"/></svg>
    <div><h2>{% if section.settings.heading != blank %}{{ section.settings.heading }}{% else %}{{ 'community.heading' | t }}{% endif %}</h2><p>{% if section.settings.handle != blank %}{{ section.settings.handle }}{% else %}{{ 'community.handle' | t }}{% endif %}</p></div>
  </div>
  <div class="community__grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: routes.root_url }}" class="community__item" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 700 | image_tag: widths: '240, 420, 700', loading: 'lazy' }}{% else %}<span class="community__fallback">{{ 'lifestyle-1' | placeholder_svg_tag }}</span>{% endif %}
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .community { padding-bottom: clamp(3rem, 6vw, 5.5rem); display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: center; }
  .community__intro { display: flex; align-items: center; gap: 1rem; }
  .community__intro svg { width: 35px; fill: none; stroke: currentColor; stroke-width: 1.5; }
  .community__intro h2, .community__intro p { margin: 0; }
  .community__intro h2 { font-family: inherit; font-size: 1rem; font-weight: 750; }
  .community__intro p { margin-top: .25rem; font-size: .82rem; }
  .community__grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: .7rem; }
  .community__item { aspect-ratio: 4 / 3; border-radius: var(--radius); overflow: hidden; background: var(--surface); }
  .community__item img, .community__item svg, .community__fallback { width: 100%; height: 100%; object-fit: cover; }
  .community__item img { transition: transform .35s ease; }
  .community__item:hover img { transform: scale(1.05); }
  @media (max-width: 1000px) { .community { grid-template-columns: 1fr; } .community__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 520px) { .community__grid { grid-template-columns: repeat(2, 1fr); } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.community.name",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.community.heading" },
    { "type": "text", "id": "handle", "label": "t:sections.community.handle" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.community.image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "t:sections.community.image" },
        { "type": "url", "id": "link", "label": "t:sections.community.link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "t:sections.community.name", "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }] }]
}
{% endschema %}
