{% liquid
  assign selected_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
%}
<section class="main-product page-width">
  <nav class="main-product__breadcrumbs" aria-label="{{ 'product.breadcrumbs' | t }}">
    <a href="{{ routes.root_url }}">{{ 'header.home' | t }}</a><span aria-hidden="true">/</span>
    {% if collection != blank %}<a href="{{ collection.url }}">{{ collection.title }}</a><span aria-hidden="true">/</span>{% endif %}
    <span aria-current="page">{{ product.title }}</span>
  </nav>
  <div class="main-product__media">
    {% if product.images.size > 0 %}
      {% for image in product.images limit: 6 %}
        {% liquid
          assign image_loading = 'lazy'
          if forloop.first
            assign image_loading = 'eager'
          endif
        %}
        <div class="main-product__image">{{ image | image_url: width: 1400 | image_tag: widths: '480, 720, 1000, 1400', sizes: '(min-width: 800px) 27vw, 100vw', loading: image_loading }}</div>
      {% endfor %}
    {% else %}
      <div class="main-product__image">{{ 'product-1' | placeholder_svg_tag }}</div>
    {% endif %}
  </div>
  <product-purchase class="main-product__details" data-add-label="{{ 'product.add_to_cart' | t | escape }}" data-sold-out-label="{{ 'product.sold_out' | t | escape }}">
    {% if product.type != blank or product.vendor != blank %}<p class="main-product__eyebrow">{% if product.type != blank %}{{ product.type }}{% else %}{{ product.vendor }}{% endif %}</p>{% endif %}
    <h1>{{ product.title }}</h1>
    {% if product.metafields.leafer.short_claim.value != blank %}<p class="main-product__claim">{{ product.metafields.leafer.short_claim.value }}</p>{% endif %}
    <p class="main-product__price" data-product-price aria-live="polite">{{ selected_variant.price | money }}</p>
    {% form 'product', product, id: product_form_id %}
      {% unless product.has_only_default_variant %}
        <label for="Variant-{{ section.id }}">{{ 'product.variant' | t }}</label>
        <select id="Variant-{{ section.id }}" name="id">
          {% for variant in product.variants %}
            <option value="{{ variant.id }}" data-price="{{ variant.price | money | escape }}" data-available="{{ variant.available }}"{% if variant == selected_variant %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>
              {{ variant.title }} · {{ variant.price | money }}{% unless variant.available %} · {{ 'product.sold_out' | t }}{% endunless %}
            </option>
          {% endfor %}
        </select>
      {% else %}
        <input type="hidden" name="id" value="{{ selected_variant.id }}">
      {% endunless %}
      <label for="Quantity-{{ section.id }}">{{ 'product.quantity' | t }}</label>
      <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">
      <button type="submit" name="add" data-product-submit{% unless selected_variant.available %} disabled{% endunless %}>
        {% if selected_variant.available %}{{ 'product.add_to_cart' | t }}{% else %}{{ 'product.sold_out' | t }}{% endif %}
      </button>
      {{ form | payment_button }}
    {% endform %}
    <div class="main-product__reassurance" aria-label="{{ 'product.purchase_benefits' | t }}">
      <span>✓ {{ 'services.shipping_title' | t }}</span>
      <span>✓ {{ 'services.payment_title' | t }}</span>
      <span>✓ {{ 'services.support_title' | t }}</span>
    </div>
    {% if section.settings.show_description and product.description != blank %}<div class="main-product__description rte">{{ product.description }}</div>{% endif %}
  </product-purchase>
  <div class="main-product__dock">
    <div><small>{{ product.title | truncate: 42 }}</small><strong data-product-price>{{ selected_variant.price | money }}</strong></div>
    <button type="submit" form="{{ product_form_id }}" name="add" data-product-submit{% unless selected_variant.available %} disabled{% endunless %}>{% if selected_variant.available %}{{ 'product.add_to_cart' | t }}{% else %}{{ 'product.sold_out' | t }}{% endif %}</button>
  </div>
</section>

{% stylesheet %}
  .main-product { padding-block: clamp(1rem, 4vw, 4rem); display: grid; grid-template-columns: minmax(0, 1.35fr) minmax(320px, .65fr); gap: clamp(2rem, 6vw, 6rem); align-items: start; }
  .main-product__breadcrumbs { grid-column: 1 / -1; display: flex; flex-wrap: wrap; gap: .45rem; color: var(--muted); font-size: .75rem; }
  .main-product__breadcrumbs a { color: inherit; }
  .main-product__media { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .8rem; }
  .main-product__image { aspect-ratio: 4 / 5; display: grid; place-items: center; overflow: hidden; padding: clamp(1rem, 3vw, 2.8rem); border: 1px solid var(--border); border-radius: var(--radius); background: #f5f2eb; }
  .main-product__image img, .main-product__image svg { width: 100%; height: 100%; object-fit: contain; object-position: center; }
  .main-product__details { position: sticky; top: 110px; }
  .main-product__eyebrow { margin: 0 0 .65rem; color: var(--accent); font-size: .72rem; font-weight: 800; letter-spacing: .11em; text-transform: uppercase; }
  .main-product h1 { margin: 0; font-size: clamp(2.5rem, 5vw, 5rem); line-height: .95; letter-spacing: -.06em; }
  .main-product__price { font-size: 1.35rem; font-weight: 750; }
  .main-product__claim { margin: 1rem 0 0; color: var(--muted); font-size: 1.05rem; }
  .main-product form { display: grid; gap: .7rem; margin-block: 2rem; }
  .main-product label { font-size: .85rem; font-weight: 750; }
  .main-product select, .main-product input { width: 100%; min-height: 48px; border: 1px solid color-mix(in srgb, var(--text), transparent 70%); border-radius: 12px; background: transparent; padding: .7rem .9rem; }
  .main-product button[disabled] { cursor: not-allowed; opacity: .5; }
  .main-product__reassurance { display: grid; grid-template-columns: repeat(3, 1fr); gap: .65rem; padding: 1rem 0 1.5rem; border-bottom: 1px solid var(--border); color: var(--muted); font-size: .72rem; }
  .main-product__description { padding-top: 1rem; border-top: 1px solid color-mix(in srgb, var(--text), transparent 85%); }
  .main-product__description > *:first-child { margin-top: 0; }
  .main-product__description > *:last-child { margin-bottom: 0; }
  .main-product__dock { display: none; }
  @media (max-width: 800px) {
    .main-product { grid-template-columns: 1fr; padding-bottom: 7rem; }
    .main-product__details { position: static; }
    .main-product__image { min-width: 92%; padding: .55rem; aspect-ratio: 1 / 1.12; }
    .main-product__media { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; margin-inline: -.75rem; padding-inline: .75rem; }
    .main-product__media::-webkit-scrollbar { display: none; }
    .main-product__image { min-width: 88%; scroll-snap-align: center; }
    .main-product h1 { font-size: clamp(2.35rem, 11vw, 4rem); line-height: .94; }
    .main-product__claim { font-size: 1rem; line-height: 1.5; }
    .main-product__description { font-size: 1rem; }
    .main-product__reassurance { grid-template-columns: 1fr; }
    .main-product__dock { position: fixed; z-index: 25; inset: auto .75rem .75rem; min-height: 72px; display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: .8rem; padding: .7rem; border: 1px solid var(--border); border-radius: 14px; background: color-mix(in srgb, var(--background), transparent 3%); box-shadow: 0 16px 42px color-mix(in srgb, var(--text), transparent 78%); backdrop-filter: blur(18px); }
    .main-product__dock small, .main-product__dock strong { display: block; }
    .main-product__dock small { overflow: hidden; color: var(--muted); font-size: .67rem; text-overflow: ellipsis; white-space: nowrap; }
    .main-product__dock strong { font-size: 1rem; }
    .main-product__dock button { min-height: 50px; padding-inline: 1rem; }
  }
{% endstylesheet %}

{% javascript %}
  class ProductPurchase extends HTMLElement {
    connectedCallback() {
      this.select = this.querySelector('select[name="id"]');
      if (!this.select) return;
      this.select.addEventListener('change', () => this.updateVariant());
    }

    updateVariant() {
      const option = this.select.selectedOptions[0];
      const available = option.dataset.available === 'true';
      const section = this.closest('.main-product');
      section.querySelectorAll('[data-product-price]').forEach((price) => { price.textContent = option.dataset.price; });
      section.querySelectorAll('[data-product-submit]').forEach((button) => {
        button.disabled = !available;
        button.textContent = available ? this.dataset.addLabel : this.dataset.soldOutLabel;
      });
      const url = new URL(window.location.href);
      url.searchParams.set('variant', option.value);
      window.history.replaceState({}, '', url);
    }
  }

  if (!customElements.get('product-purchase')) customElements.define('product-purchase', ProductPurchase);
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.main_product.name",
  "settings": [
    { "type": "checkbox", "id": "show_description", "label": "t:sections.main_product.show_description", "default": true }
  ]
}
{% endschema %}
