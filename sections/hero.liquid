{% liquid
  assign hero_heading = section.settings.heading
  if hero_heading == blank
    assign hero_heading = 'hero.heading' | t
  endif
%}
<section class="hero" style="--hero-overlay: {{ section.settings.overlay | divided_by: 100.0 }}">
  {% if section.settings.image != blank %}
    {{ section.settings.image | image_url: width: 2600 | image_tag: widths: '750, 1100, 1500, 2000, 2600', sizes: '100vw', loading: 'eager', class: 'hero__image' }}
  {% else %}
    <div class="hero__fallback"><span></span><span></span><span></span></div>
  {% endif %}
  <div class="hero__shade"></div>
  <div class="page-width hero__inner">
    <div class="hero__content">
      <h1>{{ hero_heading }}</h1>
      {% if section.settings.text != blank %}<div class="hero__text">{{ section.settings.text }}</div>{% else %}<p>{{ 'hero.text' | t }}</p>{% endif %}
      <div class="hero__buttons">
        {% if section.settings.primary_link != blank %}<a class="button" href="{{ section.settings.primary_link }}">{% if section.settings.primary_label != blank %}{{ section.settings.primary_label }}{% else %}{{ 'general.shop_now' | t }}{% endif %}</a>{% endif %}
        {% if section.settings.secondary_link != blank %}<a class="button button--secondary" href="{{ section.settings.secondary_link }}">{% if section.settings.secondary_label != blank %}{{ section.settings.secondary_label }}{% else %}{{ 'hero.configure' | t }}{% endif %}</a>{% endif %}
      </div>
    </div>
    {% if section.blocks.size > 0 %}
      <div class="hero__benefits">
        {% for block in section.blocks %}
          <div class="hero__benefit" {{ block.shopify_attributes }}>
            <svg viewBox="0 0 32 32" aria-hidden="true">
              {% case block.settings.icon %}
                {% when 'shipping' %}<path d="M3 9h16v13H3zM19 14h5l5 5v3H19zM8 26a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM24 26a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                {% when 'quality' %}<path d="M8 11h16l-1 17H9L8 11ZM12 11V7a4 4 0 0 1 8 0v4M13 17l3 3 5-6"/>
                {% else %}<path d="M16 29V15M16 23C9 22 5 18 5 10c7 0 11 4 11 11M16 18c6-1 10-5 11-12-7 0-11 4-11 10"/>
              {% endcase %}
            </svg>
            <div>
              {% if block.settings.heading != blank %}
                <strong>{{ block.settings.heading }}</strong>
              {% else %}
                <strong>{% case block.settings.icon %}{% when 'shipping' %}{{ 'hero.benefits.shipping_title' | t }}{% when 'quality' %}{{ 'hero.benefits.quality_title' | t }}{% else %}{{ 'hero.benefits.natural_title' | t }}{% endcase %}</strong>
              {% endif %}
              {% if block.settings.text != blank %}
                <span>{{ block.settings.text }}</span>
              {% else %}
                <span>{% case block.settings.icon %}{% when 'shipping' %}{{ 'hero.benefits.shipping_text' | t }}{% when 'quality' %}{{ 'hero.benefits.quality_text' | t }}{% else %}{{ 'hero.benefits.natural_text' | t }}{% endcase %}</span>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .hero { position: relative; min-height: clamp(560px, 68vw, 720px); display: grid; overflow: hidden; background: #c9c0ae; }
  .hero__image, .hero__shade, .hero__fallback { position: absolute; inset: 0; width: 100%; height: 100%; }
  .hero__image { object-fit: cover; object-position: center; }
  .hero__shade { background: linear-gradient(90deg, rgba(232,226,213,var(--hero-overlay)) 0%, rgba(232,226,213,.65) 42%, rgba(232,226,213,.05) 72%); }
  .hero__fallback { background: linear-gradient(110deg, #d7cfbf 0 44%, #b4ab97 44% 66%, #53643f 66%); }
  .hero__fallback span { position: absolute; right: 6%; bottom: -10%; width: 18%; height: 85%; border-radius: 100% 0 100% 0; background: #243c1c; transform: rotate(24deg); opacity: .9; }
  .hero__fallback span:nth-child(2) { right: 21%; bottom: -18%; width: 13%; height: 72%; transform: rotate(-17deg); background: #687a45; }
  .hero__fallback span:nth-child(3) { right: 36%; bottom: 6%; width: 15%; height: 60%; border-radius: 9px; background: #f0e7d7; transform: none; }
  .hero__inner { position: relative; display: grid; align-content: space-between; min-height: inherit; padding-block: clamp(4rem, 8vw, 6.5rem) 2.6rem; }
  .hero__content { max-width: 690px; }
  .hero h1 { margin: 0 0 1.2rem; font-size: clamp(3.2rem, 6vw, 6.2rem); line-height: .98; letter-spacing: -.035em; text-wrap: balance; }
  .hero__text, .hero__content > p { max-width: 570px; font-size: 1.16rem; }
  .hero__text > *:first-child { margin-top: 0; }
  .hero__text > *:last-child { margin-bottom: 0; }
  .hero__buttons { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1.8rem; }
  .hero .button { border: 1px solid var(--accent); border-radius: 5px; background: var(--accent); color: #fff; }
  .hero .button--secondary { border-color: color-mix(in srgb, var(--text), transparent 35%); background: transparent; color: var(--text); }
  .hero__benefits { display: flex; flex-wrap: wrap; gap: clamp(1.6rem, 4vw, 4rem); margin-top: 4rem; }
  .hero__benefit { display: flex; align-items: center; gap: .75rem; max-width: 210px; }
  .hero__benefit svg { width: 31px; flex: 0 0 auto; fill: none; stroke: currentColor; stroke-width: 1.35; stroke-linecap: round; stroke-linejoin: round; }
  .hero__benefit strong, .hero__benefit span { display: block; }
  .hero__benefit strong { font-size: .82rem; }
  .hero__benefit span { font-size: .75rem; }
  @media (max-width: 700px) { .hero { min-height: min(860px, 100svh); } .hero__image { height: 48%; object-position: center 38%; } .hero__shade { background: linear-gradient(0deg, rgba(232,226,213,1) 0 54%, rgba(232,226,213,.7) 72%, rgba(232,226,213,.08) 100%); } .hero__inner { align-content: end; padding-block: 2rem 1.25rem; } .hero__content { padding-top: min(44svh, 360px); } .hero h1 { max-width: 560px; font-size: clamp(2.45rem, 11.2vw, 4.2rem); line-height: .94; letter-spacing: -.045em; } .hero__content > p, .hero__text { font-size: 1rem; line-height: 1.55; } .hero__buttons { display: grid; grid-template-columns: 1fr; gap: .65rem; margin-top: 1.2rem; } .hero__buttons .button { width: 100%; } .hero__benefits { display: grid; grid-template-columns: 1fr 1fr; gap: .85rem; margin-top: 1.4rem; } .hero__benefit { align-items: flex-start; } }
  @media (max-width: 420px) { .hero__benefits { grid-template-columns: 1fr; } .hero { min-height: 900px; } .hero__image { height: 42%; } .hero__content { padding-top: 38svh; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero.name",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "t:sections.hero.image" },
    { "type": "range", "id": "overlay", "label": "t:sections.hero.overlay", "min": 20, "max": 100, "step": 5, "default": 80, "unit": "%" },
    { "type": "text", "id": "heading", "label": "t:sections.hero.heading" },
    { "type": "richtext", "id": "text", "label": "t:sections.hero.text" },
    { "type": "text", "id": "primary_label", "label": "t:sections.hero.primary_label" },
    { "type": "url", "id": "primary_link", "label": "t:sections.hero.primary_link" },
    { "type": "text", "id": "secondary_label", "label": "t:sections.hero.secondary_label" },
    { "type": "url", "id": "secondary_link", "label": "t:sections.hero.secondary_link" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "t:sections.hero.benefit",
      "settings": [
        { "type": "select", "id": "icon", "label": "t:sections.hero.icon", "options": [
          { "value": "shipping", "label": "t:options.shipping" },
          { "value": "quality", "label": "t:options.quality" },
          { "value": "natural", "label": "t:options.natural" }
        ], "default": "natural" },
        { "type": "text", "id": "heading", "label": "t:sections.hero.benefit_heading" },
        { "type": "text", "id": "text", "label": "t:sections.hero.benefit_text" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [{ "name": "t:sections.hero.name", "blocks": [{ "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }] }]
}
{% endschema %}
