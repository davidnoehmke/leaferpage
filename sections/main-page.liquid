<article class="main-page page-width">
  <h1>{{ page.title }}</h1>
  <div class="main-page__content">{{ page.content }}</div>
</article>

{% stylesheet %}
  .main-page { max-width: 820px; padding-block: clamp(3rem, 7vw, 7rem); }
  .main-page h1 { font-size: clamp(3rem, 8vw, 6rem); line-height: .95; letter-spacing: -.06em; }
  .main-page__content { font-size: 1.1rem; }
{% endstylesheet %}

{% schema %}
{ "name": "t:sections.main_page.name", "settings": [] }
{% endschema %}
