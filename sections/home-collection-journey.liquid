{% liquid
  assign section_heading = section.settings.heading
  assign section_intro = section.settings.intro
%}

<section class="home-journey" id="HomeJourney-{{ section.id }}" aria-labelledby="HomeJourneyHeading-{{ section.id }}">
  <div class="page-width">
    {% if section_heading != blank or section_intro != blank or section.settings.eyebrow != blank %}
      <header class="home-journey__header">
        {% if section.settings.eyebrow != blank %}
          <p class="home-journey__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}
        {% if section_heading != blank %}
          <h2 id="HomeJourneyHeading-{{ section.id }}">{{ section_heading | escape }}</h2>
        {% endif %}
        {% if section_intro != blank %}
          <div class="home-journey__intro rte">{{ section_intro }}</div>
        {% endif %}
      </header>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="home-journey__grid" role="list">
        {% for block in section.blocks %}
          {% liquid
            assign selected_collection = block.settings.collection
            assign card_title = block.settings.title
            assign card_copy = block.settings.copy
            assign destination = block.settings.fallback_link

            if selected_collection != blank
              assign destination = selected_collection.url
              if card_title == blank
                assign card_title = selected_collection.title
              endif
              if card_copy == blank and selected_collection.description != blank
                assign card_copy = selected_collection.description | strip_html | truncate: 180
              endif
            endif

            if card_title == blank
              assign card_title = block.settings.fallback_title
            endif
            if card_copy == blank
              assign card_copy = block.settings.fallback_copy
            endif
            if destination == blank
              assign destination = routes.collections_url
            endif
          %}

          <article class="home-journey__card" role="listitem" {{ block.shopify_attributes }}>
            <a class="home-journey__media" href="{{ destination }}" aria-label="{{ card_title | escape }}">
              {% if selected_collection.featured_image != blank %}
                {{ selected_collection.featured_image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '360, 540, 720, 1000', sizes: '(min-width: 990px) 25vw, (min-width: 600px) 50vw, 100vw', alt: card_title }}
              {% elsif block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '360, 540, 720, 1000', sizes: '(min-width: 990px) 25vw, (min-width: 600px) 50vw, 100vw', alt: card_title }}
              {% else %}
                <span class="home-journey__placeholder" aria-hidden="true">{{ 'collection-1' | placeholder_svg_tag }}</span>
              {% endif %}
            </a>

            <div class="home-journey__body">
              <p class="home-journey__step" aria-hidden="true">0{{ forloop.index }}</p>
              {% if card_title != blank %}
                <h3><a href="{{ destination }}">{{ card_title | escape }}</a></h3>
              {% endif %}
              {% if card_copy != blank %}
                <p>{{ card_copy | escape }}</p>
              {% endif %}
              <a class="home-journey__link" href="{{ destination }}">
                {{ block.settings.cta_label | default: 'Entdecken' | escape }}
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .home-journey { padding: var(--space-section) 0; background: color-mix(in srgb, var(--surface), var(--background) 38%); }
  .home-journey__header { max-width: 760px; margin-bottom: clamp(2rem, 5vw, 4rem); }
  .home-journey__eyebrow { margin: 0 0 .8rem; color: var(--accent); font-size: .78rem; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
  .home-journey h2 { margin: 0 0 1rem; font-size: clamp(2rem, 5vw, 4.8rem); line-height: .98; }
  .home-journey__intro { max-width: 66ch; color: var(--muted); font-size: clamp(1rem, 1.5vw, 1.18rem); }
  .home-journey__grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; }
  .home-journey__card { min-width: 0; overflow: hidden; border: 1px solid var(--border); border-radius: var(--radius-large); background: var(--background); box-shadow: var(--shadow-soft); }
  .home-journey__media { display: block; aspect-ratio: 4 / 5; overflow: hidden; background: var(--accent-soft); }
  .home-journey__media img,
  .home-journey__placeholder,
  .home-journey__placeholder svg { width: 100%; height: 100%; object-fit: cover; }
  .home-journey__media img { transition: transform .55s var(--ease-out); }
  .home-journey__card:hover .home-journey__media img { transform: scale(1.035); }
  .home-journey__body { padding: 1.25rem; }
  .home-journey__step { margin: 0 0 .5rem; color: var(--accent); font-size: .75rem; font-weight: 800; letter-spacing: .12em; }
  .home-journey h3 { margin: 0 0 .65rem; font-size: clamp(1.35rem, 2vw, 1.85rem); }
  .home-journey h3 a { text-decoration: none; }
  .home-journey__body > p:not(.home-journey__step) { min-height: 4.8em; margin: 0 0 1rem; color: var(--muted); }
  .home-journey__link { display: inline-flex; align-items: center; gap: .45rem; color: var(--accent); font-weight: 800; text-decoration: none; }
  .home-journey__link span { transition: transform .25s var(--ease-out); }
  .home-journey__link:hover span { transform: translateX(.2rem); }

  @media (max-width: 990px) {
    .home-journey__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 600px) {
    .home-journey__grid { grid-template-columns: 1fr; }
    .home-journey__media { aspect-ratio: 16 / 10; }
    .home-journey__body > p:not(.home-journey__step) { min-height: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-journey__media img,
    .home-journey__link span { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Home Kollektionen",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Kicker", "default": "LEAFers Pflanzenpflege-System" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Was braucht deine Pflanze wirklich?" },
    { "type": "richtext", "id": "intro", "label": "Einleitung", "default": "<p>Starte mit dem Bedarf deiner Pflanze. Entdecke Substrate, Zusätze, Pflanzgefäße und smartes Zubehör als aufeinander abgestimmtes System.</p>" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Kollektion",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Kollektion" },
        { "type": "image_picker", "id": "image", "label": "Fallback-Bild" },
        { "type": "text", "id": "title", "label": "Titel-Override" },
        { "type": "textarea", "id": "copy", "label": "Text-Override" },
        { "type": "text", "id": "cta_label", "label": "CTA", "default": "Entdecken" },
        { "type": "url", "id": "fallback_link", "label": "Fallback-Link" },
        { "type": "text", "id": "fallback_title", "label": "Fallback-Titel" },
        { "type": "textarea", "id": "fallback_copy", "label": "Fallback-Text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Kollektionen",
      "blocks": [
        { "type": "collection", "settings": { "fallback_title": "Premium Substrate", "fallback_copy": "Ausgewogene Basismischungen für stabile Wurzeln, kontrollierte Feuchtigkeit und eine dauerhaft lockere Struktur." } },
        { "type": "collection", "settings": { "fallback_title": "Substratzusätze", "fallback_copy": "Gezielte Komponenten für mehr Luft, Drainage, Wasserspeicherung oder Struktur – passend zur Pflanze dosierbar." } },
        { "type": "collection", "settings": { "fallback_title": "Pflanzgefäße", "fallback_copy": "Gefäße, die Wurzelraum, Wasserführung und Alltagstauglichkeit zusammenbringen." } },
        { "type": "collection", "settings": { "fallback_title": "SmartGrow & Zubehör", "fallback_copy": "Praktische Helfer für Gießen, Kontrolle und Pflege – sinnvoll ergänzt statt unnötig kompliziert." } }
      ]
    }
  ]
}
{% endschema %}
