<section class="category-grid page-width">
  {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
  <div class="category-grid__items">
    {% if section.settings.automatic %}
      {% for collection_item in collections limit: section.settings.automatic_limit %}
        {% liquid
          assign tile_image = collection_item.image
          if tile_image == blank
            assign tile_image = collection_item.products.first.featured_image
          endif
        %}
        <a class="category-grid__card" href="{{ collection_item.url }}">
          {% if tile_image != blank %}{{ tile_image | image_url: width: 900 | image_tag: widths: '320, 520, 700, 900', sizes: '(min-width: 900px) 16vw, 50vw', loading: 'lazy' }}{% else %}<div class="category-grid__fallback"></div>{% endif %}
          <span class="category-grid__shade"></span>
          <span class="category-grid__copy">
            <svg viewBox="0 0 40 40" aria-hidden="true"><path d="M20 35V19M20 29c-8-1-13-6-13-15 8 0 13 5 13 13M20 23c7-1 12-6 13-15-8 0-13 5-13 12"/></svg>
            <strong>{{ collection_item.title }}</strong>
            <small>{{ 'general.discover' | t }}</small>
          </span>
        </a>
      {% else %}
        <p class="category-grid__empty">{{ 'categories.empty' | t }}</p>
      {% endfor %}
    {% else %}
      {% for block in section.blocks %}
        {% liquid
          assign tile_image = block.settings.image
          if tile_image == blank
            assign tile_image = block.settings.collection.image
          endif
          if tile_image == blank
            assign tile_image = block.settings.collection.products.first.featured_image
          endif
          assign tile_link = block.settings.collection.url | default: routes.collections_url
          assign title_key = 'categories.' | append: block.settings.icon
        %}
        <a class="category-grid__card" href="{{ tile_link }}" {{ block.shopify_attributes }}>
          {% if tile_image != blank %}{{ tile_image | image_url: width: 900 | image_tag: widths: '320, 520, 700, 900', sizes: '(min-width: 900px) 16vw, 50vw', loading: 'lazy' }}{% else %}<div class="category-grid__fallback"></div>{% endif %}
          <span class="category-grid__shade"></span>
          <span class="category-grid__copy">
            <svg viewBox="0 0 40 40" aria-hidden="true"><path d="M20 35V19M20 29c-8-1-13-6-13-15 8 0 13 5 13 13M20 23c7-1 12-6 13-15-8 0-13 5-13 12"/></svg>
            <strong>{% if block.settings.title != blank %}{{ block.settings.title }}{% else %}{{ title_key | t }}{% endif %}</strong>
            <small>{{ 'general.discover' | t }}</small>
          </span>
        </a>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .category-grid { padding-bottom: clamp(2rem, 5vw, 4rem); }
  .category-grid > h2 { margin-bottom: 1.2rem; font-size: 2rem; }
  .category-grid__items { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: .55rem; }
  .category-grid__card { position: relative; min-height: 210px; border-radius: var(--radius); overflow: hidden; color: #fff; text-decoration: none; }
  .category-grid__card img, .category-grid__fallback, .category-grid__shade { position: absolute; inset: 0; width: 100%; height: 100%; }
  .category-grid__card img { object-fit: cover; transition: transform .35s ease; }
  .category-grid__card:hover img { transform: scale(1.04); }
  .category-grid__fallback { background: radial-gradient(circle at 70% 20%, #7d9669, transparent 30%), linear-gradient(135deg, #526542, #1f2e1a); }
  .category-grid__shade { background: linear-gradient(0deg, rgba(8,15,6,.8), rgba(8,15,6,.08)); }
  .category-grid__copy { position: absolute; inset: auto 1rem 1rem; display: grid; justify-items: center; gap: .2rem; text-align: center; }
  .category-grid__copy svg { width: 36px; fill: none; stroke: currentColor; stroke-width: 1.3; stroke-linecap: round; stroke-linejoin: round; }
  .category-grid__copy strong { font-family: var(--heading-font); font-size: 1.2rem; line-height: 1.1; }
  .category-grid__copy small { margin-top: .45rem; font-size: .7rem; }
  .category-grid__empty { grid-column: 1 / -1; padding: 2rem; border: 1px dashed var(--border); text-align: center; }
  @media (max-width: 1050px) { .category-grid__items { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 600px) { .category-grid__items { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .45rem; } .category-grid__card { min-height: 210px; } .category-grid__copy { inset: auto .65rem .75rem; } .category-grid__copy strong { font-size: 1.05rem; } .category-grid__card img { object-position: center; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.category_grid.name",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.category_grid.heading" },
    { "type": "checkbox", "id": "automatic", "label": "t:sections.category_grid.automatic", "info": "t:sections.category_grid.automatic_info", "default": true },
    { "type": "range", "id": "automatic_limit", "label": "t:sections.category_grid.automatic_limit", "min": 2, "max": 8, "step": 1, "default": 6 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "t:sections.category_grid.category",
      "settings": [
        { "type": "select", "id": "icon", "label": "t:sections.category_grid.icon", "options": [
          { "value": "substrates", "label": "t:options.substrates" },
          { "value": "planters", "label": "t:options.planters" },
          { "value": "seeds", "label": "t:options.seeds" },
          { "value": "kits", "label": "t:options.kits" },
          { "value": "accessories", "label": "t:options.accessories" },
          { "value": "young_plants", "label": "t:options.young_plants" }
        ], "default": "substrates" },
        { "type": "text", "id": "title", "label": "t:sections.category_grid.title" },
        { "type": "image_picker", "id": "image", "label": "t:sections.category_grid.image" },
        { "type": "collection", "id": "collection", "label": "t:sections.category_grid.collection" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "t:sections.category_grid.name" }]
}
{% endschema %}
