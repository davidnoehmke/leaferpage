<header class="site-header" style="--logo-width: {{ section.settings.logo_width }}px">
  <div class="page-width site-header__inner">
    <a class="site-header__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 480 | image_tag: widths: '160, 240, 320, 480', loading: 'eager', alt: shop.name }}
      {% else %}
        <svg viewBox="0 0 38 42" aria-hidden="true"><path d="M19 39V18M19 29C10 28 5 22 5 12c9 0 14 5 14 14M19 22c7-1 12-6 13-15-8 0-13 5-13 12M13 15C13 9 16 5 21 2c3 6 2 11-2 15" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>{{ shop.name }}</span>
      {% endif %}
    </a>
    {% if section.settings.menu != blank %}
      <nav class="site-header__desktop" aria-label="{{ 'accessibility.menu' | t }}">
        {% for link in section.settings.menu.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}
      </nav>
    {% endif %}
    <div class="site-header__actions">
      <a href="{{ routes.search_url }}" aria-label="{{ 'header.search' | t }}"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.8" cy="10.8" r="6.8"/><path d="m16 16 4.5 4.5"/></svg></a>
      <a class="site-header__account" href="{{ routes.account_login_url }}" aria-label="{{ 'header.account' | t }}"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="7.5" r="4"/><path d="M4.5 21c.5-5 3-7.5 7.5-7.5s7 2.5 7.5 7.5"/></svg></a>
      <a class="site-header__cart" href="{{ routes.cart_url }}" aria-label="{{ 'header.cart' | t: count: cart.item_count }}"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2.5 4h2l2 11.5h11.5l2-8.5H6"/><circle cx="9" cy="20" r="1.2"/><circle cx="17" cy="20" r="1.2"/></svg>{% if cart.item_count > 0 %}<span>{{ cart.item_count }}</span>{% endif %}</a>
      {% if section.settings.menu != blank %}
        <details class="site-header__mobile">
          <summary aria-label="{{ 'accessibility.menu' | t }}"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg></summary>
          <nav>{% for link in section.settings.menu.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}</nav>
        </details>
      {% endif %}
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header { position: sticky; z-index: 20; top: 0; border-bottom: 1px solid var(--border); background: color-mix(in srgb, var(--background), transparent 3%); backdrop-filter: blur(14px); }
  .site-header__inner { min-height: 78px; display: grid; grid-template-columns: minmax(180px, 1fr) auto minmax(180px, 1fr); align-items: center; gap: 2.5rem; }
  .site-header__brand { width: min(100%, var(--logo-width)); display: inline-flex; align-items: center; gap: .55rem; font-family: var(--heading-font); font-size: 1.45rem; font-weight: 600; text-decoration: none; }
  .site-header__brand > svg { width: 34px; flex: 0 0 auto; }
  .site-header__brand img { width: 100%; height: auto; }
  .site-header__desktop { display: flex; justify-content: center; gap: clamp(1rem, 2.4vw, 2.6rem); white-space: nowrap; }
  .site-header__desktop a { position: relative; font-size: .87rem; font-weight: 650; text-decoration: none; }
  .site-header__desktop a::after { content: ""; position: absolute; left: 0; right: 0; bottom: -.45rem; height: 1px; background: currentColor; transform: scaleX(0); transform-origin: right; transition: transform .25s var(--ease-out); }
  .site-header__desktop a:hover::after { transform: scaleX(1); transform-origin: left; }
  .site-header__desktop a:hover { color: var(--accent); }
  .site-header__actions { justify-self: end; display: flex; align-items: center; gap: 1.15rem; }
  .site-header__actions > a, .site-header__mobile summary { position: relative; display: grid; place-items: center; width: 44px; height: 44px; cursor: pointer; border-radius: 50%; }
  .site-header__actions > a:hover, .site-header__mobile summary:hover { background: var(--surface); }
  .site-header__actions svg { width: 24px; fill: none; stroke: currentColor; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .site-header__cart span { position: absolute; top: -6px; right: -9px; min-width: 17px; height: 17px; padding-inline: 3px; border-radius: 50%; display: grid; place-items: center; background: var(--accent); color: #fff; font-size: .65rem; font-weight: 800; }
  .site-header__mobile { display: none; position: relative; }
  .site-header__mobile summary { list-style: none; }
  .site-header__mobile nav { position: fixed; z-index: 30; inset-inline: 0; top: 112px; max-height: calc(100dvh - 112px); overflow: auto; padding: 1.25rem max(1rem, calc((100vw - var(--page-width)) / 2)); border-top: 1px solid var(--border); background: var(--background); display: grid; gap: 0; box-shadow: var(--shadow-soft); opacity: 0; transform: translateY(-12px); transition: opacity .25s var(--ease-out), transform .25s var(--ease-out); }
  .site-header__mobile[open] nav { opacity: 1; transform: none; }
  .site-header__mobile nav a { min-height: 54px; display: flex; align-items: center; border-bottom: 1px solid var(--border); text-decoration: none; font-family: var(--heading-font); font-size: 1.25rem; font-weight: 600; }
  @starting-style { .site-header__mobile[open] nav { opacity: 0; transform: translateY(-12px); } }
  @media (max-width: 1050px) { .site-header__inner { grid-template-columns: 1fr auto; } .site-header__desktop { display: none; } .site-header__mobile { display: block; } }
  @media (max-width: 520px) { .site-header__inner { min-height: 66px; gap: .35rem; } .site-header__brand { font-size: 1.15rem; } .site-header__brand > svg { width: 29px; } .site-header__account { display: none !important; } .site-header__actions { gap: .1rem; } .site-header__mobile nav { top: 100px; max-height: calc(100dvh - 100px); } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.header.name",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "t:sections.header.logo" },
    { "type": "range", "id": "logo_width", "label": "t:sections.header.logo_width", "min": 120, "max": 260, "step": 10, "default": 190, "unit": "px" },
    { "type": "link_list", "id": "menu", "label": "t:sections.header.menu", "default": "main-menu" }
  ]
}
{% endschema %}
